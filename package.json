{
  "name": "discord-activity-bot",
  "version": "1.0.0",
  "description": "Discord bot para monitorar atividade e distribuir recompensas de cargos",
  "main": "dist/bot.js",
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "build": "tsc",
    "start": "node dist/bot.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "@prisma/client": "^6.0.0",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11"
  }
}
