FROM node:22-slim

WORKDIR /app

# Install fonts (required for canvas text rendering)
RUN apt-get update && apt-get install -y --no-install-recommends \
    fonts-liberation \
    fontconfig \
    && fc-cache -fv \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Install dependencies first (cached layer — only rebuilds when package files change)
COPY package.json pnpm-lock.yaml ./
COPY prisma ./prisma/

RUN pnpm install --frozen-lockfile

# Ensure canvas native binary is built/downloaded
RUN pnpm rebuild canvas

RUN pnpm prisma generate

# src/ and prisma/ are mounted as volumes at runtime for hot reload
CMD ["pnpm", "dev"]
