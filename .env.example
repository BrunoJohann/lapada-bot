# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# PostgreSQL
# Local (Docker):   postgresql://postgres:postgres@localhost:5432/discord_bot?schema=public
# Supabase:         postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/discord_bot?schema=public

# Redis
# Local (Docker):   redis://localhost:6379
# Upstash:          rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379
REDIS_URL=redis://localhost:6379

# Config
NODE_ENV=development
TIMEZONE=America/Sao_Paulo

# Deploy de comandos (opcional)
# Se definido, registra comandos apenas neste servidor (instantâneo, ideal para dev)
# Se vazio, registra globalmente (pode demorar até 1h para aparecer)
GUILD_ID=
