# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# PostgreSQL (ex: Supabase)
DATABASE_URL="postgresql://user:password@host:5432/discord_bot?schema=public"

# Redis (ex: Upstash)
REDIS_URL="redis://default:password@host:port"

# Config
NODE_ENV=development
TIMEZONE=America/Sao_Paulo

# Deploy de comandos (opcional)
# Se definido, registra comandos apenas neste servidor (instantâneo, ideal para dev)
# Se vazio, registra globalmente (pode demorar até 1h)
GUILD_ID=
